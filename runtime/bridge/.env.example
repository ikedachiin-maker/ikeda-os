# LINE橋 用の環境変数（コピーして .env を作る。.env はコミットしない）

# LINE Developers > Messaging API チャンネルの値
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# サーバのポート（既定3000）
PORT=3000

# true にすると、解釈できた予定を確認なしで自動カレンダー登録する
# （secretary/.env の GOOGLE_APPLICATION_CREDENTIALS / IKEDA_CALENDAR_ID も必要）
BRIDGE_AUTO_CREATE=false
